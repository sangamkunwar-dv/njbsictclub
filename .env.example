# ====================================================================
# NJBS ICT CLUB - ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your Supabase credentials
# ====================================================================

# ========================================
# REQUIRED: SUPABASE CONFIGURATION
# ========================================
# Get these from: https://app.supabase.com
# Steps:
# 1. Login to Supabase dashboard
# 2. Click on your project
# 3. Go to "Settings" → "API" (left sidebar)
# 4. Copy the values below from the API section

# Your Supabase project URL
# Example: https://abcdefgh.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon (public) key
# Look under "Project API keys" → "anon public" key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Your Supabase service role key (KEEP THIS SECRET!)
# Look under "Project API keys" → "service_role secret" key
# Never expose this in client-side code
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ========================================
# REQUIRED: JWT SECRET
# ========================================
# Generate a random secret key
# Run this command: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Then paste the output below
JWT_SECRET=your_random_64_character_hex_string_here

# ========================================
# OPTIONAL: GOOGLE OAUTH (For Google Login)
# ========================================
# Get these from: https://console.cloud.google.com
# Steps:
# 1. Create a new project
# 2. Enable "Google+ API"
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URIs:
#    - http://localhost:3000/api/auth/callback/google (development)
#    - https://yourdomain.com/api/auth/callback/google (production)
# 5. Copy Client ID and Client Secret below

# Google Client ID (public, can be in frontend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Client Secret (SECRET! Keep in .env.local only)
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ========================================
# OPTIONAL: GITHUB OAUTH (For GitHub Login)
# ========================================
# Get these from: https://github.com/settings/developers
# Steps:
# 1. Go to Settings → Developer settings → OAuth Apps
# 2. Click "New OAuth App"
# 3. Fill in details:
#    - Application name: NJBS ICT Club
#    - Homepage URL: http://localhost:3000
#    - Authorization callback URL:
#      http://localhost:3000/api/auth/callback/github (dev)
#      https://yourdomain.com/api/auth/callback/github (prod)
# 4. Generate client secret
# 5. Copy Client ID and Client Secret below

# GitHub Client ID (public, can be in frontend)
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id_here

# GitHub Client Secret (SECRET! Keep in .env.local only)
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# ========================================
# OPTIONAL: APPLICATION SETTINGS
# ========================================

# Node environment
NODE_ENV=development

# Your application URL (for password reset links, OAuth redirects, etc)
NEXT_PUBLIC_APP_URL=http://localhost:3000
